{
  "name": "astro-starter",
  "type": "module",
  "version": "0.0.1",
  "description": "A modern, SEO-optimized Astro starter template with comprehensive meta tags, social media integration, and essential web development tools.",
  "author": "Ali Piry",
  "license": "MIT",
  "keywords": [
    "astro",
    "starter",
    "template",
    "seo",
    "web-development",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/alipiry/astro-starter.git"
  },
  "bugs": {
    "url": "https://github.com/alipiry/astro-starter/issues"
  },
  "homepage": "https://github.com/alipiry/astro-starter#readme",
  "engines": {
    "node": ">=22.13.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.25.0",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "clean": "rimraf dist .astro",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "astro check",
    "prepare": "husky"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.3",
    "astro": "^7.0.6",
    "astro-robots-txt": "^1.0.0",
    "astro-seo": "^1.1.0",
    "sharp": "^0.35.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.1.0",
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.2",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.6.0",
    "eslint-plugin-astro": "^2.1.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4",
    "prettier-plugin-astro": "^0.14.1",
    "rimraf": "^6.1.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.1.3"
  }
}
