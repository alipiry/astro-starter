{
  "name": "astro-starter",
  "type": "module",
  "version": "0.0.1",
  "description": "A modern, SEO-optimized Astro starter template with comprehensive meta tags, social media integration, and essential web development tools.",
  "author": "Ali Piry",
  "license": "MIT",
  "keywords": [
    "astro",
    "starter",
    "template",
    "seo",
    "web-development",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/alipiry/astro-starter.git"
  },
  "bugs": {
    "url": "https://github.com/alipiry/astro-starter/issues"
  },
  "homepage": "https://github.com/alipiry/astro-starter#readme",
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.25.0",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "clean": "rimraf dist .astro",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "astro check",
    "prepare": "husky"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.2",
    "astro": "^6.3.7",
    "astro-robots-txt": "^1.0.0",
    "astro-seo": "^1.1.0",
    "sharp": "^0.34.5"
  },
  "pnpm": {
    "overrides": {
      "devalue": ">=5.8.1"
    }
  },
  "devDependencies": {
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.1",
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "rimraf": "^6.1.3",
    "typescript-eslint": "^8.59.4",
    "vite": "^7.3.2"
  }
}
