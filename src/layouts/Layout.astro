---
import { APP_ENV, SITE_URL } from "astro:env/server";
import { SEO } from "astro-seo";

interface Props {
  title?: string;
  description?: string;
}

const DEFAULT_TITLE = "Astro Starter";

const siteUrl = SITE_URL;
const allowIndexing = APP_ENV === "production";
const robotsContent = allowIndexing ? "index, follow" : "noindex, nofollow";

const { title, description = DEFAULT_TITLE } = Astro.props;

const isIndexPage = Astro.url.pathname === "/";

const pageTitle = isIndexPage ? DEFAULT_TITLE : title || DEFAULT_TITLE;
const titleTemplate = isIndexPage ? "%s" : `%s | ${DEFAULT_TITLE}`;
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <SEO
      title={pageTitle}
      titleDefault={DEFAULT_TITLE}
      titleTemplate={titleTemplate}
      description={description}
      canonical={canonicalUrl}
      noindex={!allowIndexing}
      nofollow={!allowIndexing}
      openGraph={{
        basic: {
          title: title || DEFAULT_TITLE,
          type: "website",
          image: `${siteUrl}/og.png`,
          url: canonicalUrl,
        },
        image: {
          alt: DEFAULT_TITLE,
          width: 1600,
          height: 800,
          type: "image/png",
        },
        optional: {
          description,
          siteName: DEFAULT_TITLE,
          locale: "en_US",
        },
      }}
      twitter={{
        card: "summary_large_image",
        site: "@alipiry",
        creator: "@alipiry",
        title: title || DEFAULT_TITLE,
        description,
        image: `${siteUrl}/og.png`,
        imageAlt: DEFAULT_TITLE,
      }}
      extend={{
        meta: [
          { name: "author", content: "Ali Piry" },
          {
            name: "keywords",
            content:
              "astro, web development, javascript, typescript, modern web",
          },
          { name: "googlebot", content: robotsContent },
          { name: "theme-color", content: "#000000" },
          { name: "msapplication-TileColor", content: "#000000" },
        ],
        link: [
          {
            rel: "apple-touch-icon",
            sizes: "180x180",
            href: "/apple-touch-icon.png",
          },
          {
            rel: "icon",
            type: "image/svg+xml",
            href: "/favicon.svg",
          },
          {
            rel: "icon",
            type: "image/png",
            sizes: "32x32",
            href: "/favicon-32x32.png",
          },
          {
            rel: "icon",
            type: "image/png",
            sizes: "16x16",
            href: "/favicon-16x16.png",
          },
          {
            rel: "icon",
            type: "image/x-icon",
            href: "/favicon.ico",
          },
          {
            rel: "icon",
            type: "image/png",
            sizes: "192x192",
            href: "/android-chrome-192x192.png",
          },
          {
            rel: "icon",
            type: "image/png",
            sizes: "512x512",
            href: "/android-chrome-512x512.png",
          },
        ],
      }}
    />
    <link rel="sitemap" href="/sitemap-index.xml" />
  </head>
  <body>
    <slot />
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }
</style>
